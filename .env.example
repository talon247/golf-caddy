# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sentry error tracking (optional — only initialised when set)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# LogRocket session replay (optional — only initialised in production/preview builds)
VITE_LOGROCKET_APP_ID=yourapp/your-project-id

# Golf course API
VITE_GOLF_COURSE_API_KEY=your-api-key

# Discord beta community invite
VITE_DISCORD_INVITE_URL=https://discord.gg/tGycmdBjRm
